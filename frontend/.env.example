# ─── Cadencia Frontend Environment Variables ──────────────────────────────

# API Base URL — points to the backend FastAPI server
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mock Service Worker — set to "true" to use MSW mocks instead of real API
# Use "true" for local development without a backend, "false" for production
NEXT_PUBLIC_ENABLE_MOCKS=false

# WalletConnect — required for Pera/Defly wallet relay connections
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
