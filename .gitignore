node_modules/
.next/
out/
*.tsbuildinfo

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

